<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>نظام القوات المسلحة | MARVEL</title>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-firestore-compat.js"></script>
    <style>
        :root { --red: #8b0000; --gold: #d4af37; --bg: #0a0a0a; }
        body { background: var(--bg); color: white; font-family: 'Arial', sans-serif; margin: 0; text-align: center; }
        nav { background: #111; padding: 15px; border-bottom: 2px solid var(--red); display: flex; justify-content: center; gap: 10px; }
        nav button { background: none; color: white; border: 1px solid var(--red); padding: 10px 15px; cursor: pointer; font-weight: bold; }
        .section { display: none; background: #111; margin: 20px auto; padding: 20px; width: 90%; max-width: 1000px; border-right: 5px solid var(--red); text-align: right; }
        .active { display: block; }
        .card { background: #1a1a1a; padding: 15px; margin: 10px 0; border: 1px solid #333; }
        img { max-width: 100%; height: auto; border: 1px solid var(--gold); margin: 15px 0; display: block; margin-right: auto; margin-left: auto; }
        .code-box { background: #000; color: #00ff00; padding: 5px; font-family: monospace; border: 1px dashed var(--gold); }
        .prohibited { border: 1px solid #ff4444; padding: 10px; color: #ff4444; }
    </style>
</head>
<body>

<nav>
    <button onclick="showTab('apply')">تقديم طلب</button>
    <button onclick="checkAccess()">بوابة المقبولين</button>
    <button onclick="checkAdminAccess()">لوحة القادة</button>
</nav>

<div id="apply" class="section active">
    <h2>📩 انضم إلى القوات المسلحة</h2>
    <input type="text" id="name" placeholder="الاسم العسكري" style="width:90%; padding:10px; margin:10px; background:#000; color:white; border:1px solid #444;">
    <input type="text" id="discord" placeholder="معرف الديسكورد" style="width:90%; padding:10px; margin:10px; background:#000; color:white; border:1px solid #444;">
    <button onclick="sendData()" style="background:var(--red); color:white; width:95%; padding:15px; border:none; cursor:pointer; font-weight:bold;">إرسال الطلب</button>
</div>

<div id="military_system" class="section">
    <h1 style="color:var(--gold)">🎖️ الدليل العسكري الرسمي</h1>
    
    <div class="card">
        <h3>📏 بروتوكولات المناداة والتشكيل</h3>
        <p>بروتوكول الرتب:</p>
        <img src="33075ca33ac2b20a.png" alt="بروتوكول الرتب">
        <p>التشكيل الميداني:</p>
        <img src="image.png" alt="التشكيل الميداني">
    </div>

    <div class="card">
        <h3>⚖️ لائحة المخالفات والجزاءات</h3>
        <img src="IMG_0619.jpg" alt="المخالفات">
    </div>

    <div class="card">
        <h3>🚗 دليل المركبات</h3>
        <p>السيارة المخصصة للسيناريوهات: <strong>ارمادا</strong></p>
        <p>سيارة القيادة: <strong>جي كلاس</strong></p>
        <p>سيارات الوزير ونائبه: <strong>روز رايز، BMW</strong></p>
        <p>سيارات الحرس: <strong>يوكن، تاهو، سكاليد</strong></p>
        <div class="prohibited">
            <strong>🚫 يمنع استخراجها إلا بإذن علوي:</strong><br>
            ناقلة عسكرية، مدرعات، هلي كوبتر، طيارة استطلاع، F-22، F-15، قوارب، دباب.
        </div>
    </div>

    <div class="card">
        <h3>👕 التجهيزات والموجة</h3>
        <p>ميدان أفراد: <span class="code-box">59316417</span> | القوات البرية: <span class="code-box">21389850</span></p>
        <p>مداهمات أفراد: <span class="code-box">54516535</span> | القوات الجوية: <span class="code-box">78824265</span></p>
        <p>القيادة: <span class="code-box">15981693</span> | الموجة الخاصة: <strong>3</strong></p>
    </div>
</div>

<script>
    // إعدادات Firebase
    const firebaseConfig = {
        apiKey: "AIzaSyBWB-zYDHuYlQ2afaxKuOXlWKI7xAgjmTw",
        authDomain: "marvel-military.firebaseapp.com",
        projectId: "marvel-military",
        storageBucket: "marvel-military.firebasestorage.app",
        appId: "1:477826729291:web:95909db6cb7ba511fd94ce"
    };

    firebase.initializeApp(firebaseConfig);
    const db = firebase.firestore();

    function showTab(tabId) {
        document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
        document.getElementById(tabId).classList.add('active');
    }

    function checkAccess() {
        const pass = prompt("أدخل رمز الوصول العسكري:");
        if(pass === "MARVEL2026") { showTab('military_system'); }
        else { alert("دخول مرفوض!"); }
    }

    function checkAdminAccess() {
        const pass = prompt("رمز القادة:");
        if(pass === "LEADER2026") { alert("سيتم فتح لوحة الإدارة قريباً"); }
    }

    function sendData() {
        const n = document.getElementById('name').value;
        const d = document.getElementById('discord').value;
        if(n && d) {
            db.collection("applications").add({
                military_name: n, discord_id: d, status: 'pending', timestamp: new Date().toLocaleString()
            }).then(() => { alert("تم الإرسال!"); location.reload(); });
        }
    }
</script>
</body>
</html>
